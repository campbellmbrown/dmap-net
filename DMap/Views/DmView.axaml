<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DMap.ViewModels"
             xmlns:toolVm="using:DMap.ViewModels.ToolSettings"
             xmlns:toolViews="using:DMap.Views.ToolSettings"
             xmlns:controls="using:DMap.Controls"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
             x:Class="DMap.Views.DmView"
             x:DataType="vm:DmViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.toolSetting">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource DMapForeground}" />
        </Style>
        <Style Selector="TextBlock.toolSettingHeader">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource DMapHighlight}" />
        </Style>
        <Style Selector="Border.overlay">
            <Setter Property="Background" Value="{StaticResource DMapBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource DMapHighlight}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BoxShadow" Value="0 2 8 0 #40000000" />
        </Style>
        <Style Selector="Separator.toolbar">
            <Setter Property="Width" Value="2" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="Separator.toolbox">
            <Setter Property="Height" Value="2" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <!-- Toolbar button styles -->
        <Style Selector="Button.toolbar, ToggleButton.toolbar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DMapHover}" />
        </Style>
        <Style Selector="Button.toolbar:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DMapSelected}" />
        </Style>
        <Style Selector="ToggleButton.toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DMapHover}" />
        </Style>
        <Style Selector="ToggleButton.toolbar:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DMapSelected}" />
        </Style>
        <Style Selector="ToggleButton.toolbar:checked:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DMapHover}" />
        </Style>
        <Style Selector="ToggleButton.toolbar:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DMapSelected}" />
        </Style>
        <Style Selector="Button.toolbar Image, ToggleButton.toolbar Image">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
        </Style>
        <Style Selector="NumericUpDown.toolbar">
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ShowButtonSpinner" Value="False" />
            <Setter Property="Width" Value="64" />
            <Setter Property="Height" Value="20" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <!-- Toolbox button styles -->
        <Style Selector="Button.toolbox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.toolbox.toolSelected">
            <Setter Property="Background" Value="{StaticResource DMapSelected}" />
        </Style>
        <Style Selector="Button.toolbox:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DMapHover}" />
        </Style>
        <Style Selector="Button.toolbox.toolSelected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DMapHover}" />
        </Style>
        <Style Selector="Button.toolbox Image">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
        </Style>

        <Style Selector="NumericUpDown.toolSetting">
            <Setter Property="Width" Value="60" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="ShowButtonSpinner" Value="False" />
        </Style>

        <Style Selector="MenuItem Image">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
        </Style>
    </UserControl.Styles>

    <UserControl.DataTemplates>
        <DataTemplate DataType="toolVm:BrushToolSettingsViewModel">
            <toolViews:BrushToolSettingsView />
        </DataTemplate>
        <DataTemplate DataType="toolVm:ShapeToolSettingsViewModel">
            <toolViews:ShapeToolSettingsView />
        </DataTemplate>
        <DataTemplate DataType="toolVm:FogToolSettingsViewModel">
            <toolViews:FogToolSettingsView />
        </DataTemplate>
        <DataTemplate DataType="toolVm:CursorToolSettingsViewModel">
            <toolViews:CursorToolSettingsView />
        </DataTemplate>
        <DataTemplate DataType="toolVm:GridToolSettingsViewModel">
            <toolViews:GridToolSettingsView />
        </DataTemplate>
    </UserControl.DataTemplates>

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding LoadMapCommand}" />
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}" />
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+Z" Command="{Binding RedoCommand}" />
        <KeyBinding Gesture="Ctrl+OemPlus" Command="{Binding #MapCanvas.ZoomInCommand}" />
        <KeyBinding Gesture="Ctrl+OemMinus" Command="{Binding #MapCanvas.ZoomOutCommand}" />
        <KeyBinding Gesture="Ctrl+D0" Command="{Binding #MapCanvas.RefitViewCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+E" Command="{Binding RevealAllCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+F" Command="{Binding RefogAllCommand}" />
        <KeyBinding Gesture="Ctrl+M" Command="{Binding ToggleMapVisibilityCommand}" />
        <KeyBinding Gesture="F8" Command="{Binding ToggleOverlayVisibilityCommand}" />
        <KeyBinding Gesture="Ctrl+P" Command="{Binding TogglePauseUpdatesCommand}" />
    </UserControl.KeyBindings>

    <DockPanel>
        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="Open Map..." Command="{Binding LoadMapCommand}" InputGesture="Ctrl+O">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/map.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Open Log Directory" Command="{Binding OpenLogDirectoryCommand}">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/folder-open.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Exit" Command="{Binding ExitCommand}">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/door-open.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Zoom In" Command="{Binding #MapCanvas.ZoomInCommand}" InputGesture="Ctrl+OemPlus">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/zoom-in.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Zoom Out" Command="{Binding #MapCanvas.ZoomOutCommand}" InputGesture="Ctrl+OemMinus">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/zoom-out.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Refit View" Command="{Binding #MapCanvas.RefitViewCommand}" InputGesture="Ctrl+D0">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/scan-eye.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Show Map" Command="{Binding ToggleMapVisibilityCommand}" InputGesture="Ctrl+M"
                          ToggleType="CheckBox" IsChecked="{Binding IsMapVisible, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/image.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Show Tools" Command="{Binding ToggleOverlayVisibilityCommand}" InputGesture="F8"
                          ToggleType="CheckBox" IsChecked="{Binding IsOverlayVisible, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/toolbox.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Show Tool Settings"
                          Command="{Binding ToggleToolSettingsPanelVisibilityCommand}"
                          ToggleType="CheckBox"
                          IsChecked="{Binding IsToolSettingsPanelVisible, Mode=OneWay}"
                          IsEnabled="{Binding HasCurrentToolSettings}">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/palette.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Send Updates" Command="{Binding TogglePauseUpdatesCommand}" InputGesture="Ctrl+P"
                          ToggleType="CheckBox" IsChecked="{Binding !IsUpdatesPaused, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/radio.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Undo" Command="{Binding UndoCommand}" InputGesture="Ctrl+Z">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/undo-2.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Redo" Command="{Binding RedoCommand}" InputGesture="Ctrl+Y">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/redo-2.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Reveal All" Command="{Binding RevealAllCommand}" InputGesture="Ctrl+Shift+E">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/eye.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Refog All" Command="{Binding RefogAllCommand}" InputGesture="Ctrl+Shift+F">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/eye-off.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Window">
                <MenuItem Header="Open Player Window" Command="{Binding OpenPlayerWindowCommand}">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/picture-in-picture.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About DMap" Command="{Binding ShowAboutCommand}">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/info.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource DMapBackground}" BorderBrush="{StaticResource DMapHighlight}" BorderThickness="0,2,0,2">
            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        Margin="4">

                <Button Classes="toolbar" Command="{Binding UndoCommand}" ToolTip.Tip="Undo">
                    <Image Source="{SvgImage /Assets/Icons/undo-2.svg}" />
                </Button>
                <Button Classes="toolbar" Command="{Binding RedoCommand}" ToolTip.Tip="Redo">
                    <Image Source="{SvgImage /Assets/Icons/redo-2.svg}" />
                </Button>
                <Separator Classes="toolbar" />
                <ToggleButton Classes="toolbar"
                              Command="{Binding ToggleMapVisibilityCommand}"
                              IsChecked="{Binding IsMapVisible, Mode=OneWay}"
                              ToolTip.Tip="Toggle Map">
                    <Image Source="{SvgImage /Assets/Icons/image.svg}" />
                </ToggleButton>
                <Separator Classes="toolbar" />
                <ToggleButton Classes="toolbar"
                              Command="{Binding ToggleOverlayVisibilityCommand}"
                              IsChecked="{Binding IsOverlayVisible, Mode=OneWay}"
                              ToolTip.Tip="Show/Hide Tools (F8)">
                    <Image Source="{SvgImage /Assets/Icons/toolbox.svg}" />
                </ToggleButton>
                <Separator Classes="toolbar" />
                <ToggleButton Classes="toolbar"
                              Command="{Binding TogglePauseUpdatesCommand}"
                              IsChecked="{Binding !IsUpdatesPaused, Mode=OneWay}"
                              ToolTip.Tip="Pause/Resume Player Updates">
                    <Image Source="{SvgImage /Assets/Icons/radio.svg}" />
                </ToggleButton>
                <Separator Classes="toolbar" />
                <Button Classes="toolbar" Command="{Binding #MapCanvas.ZoomOutCommand}" ToolTip.Tip="Zoom Out">
                    <Image Source="{SvgImage /Assets/Icons/zoom-out.svg}" />
                </Button>
                <NumericUpDown Classes="toolbar"
                               Value="{Binding #MapCanvas.ZoomPercent, Mode=TwoWay}"
                               Minimum="10" Maximum="1000" Increment="10"
                               FormatString="0'%'"
                               ToolTip.Tip="Zoom level relative to fitted map height" />
                <Button Classes="toolbar" Command="{Binding #MapCanvas.ZoomInCommand}" ToolTip.Tip="Zoom In">
                    <Image Source="{SvgImage /Assets/Icons/zoom-in.svg}" />
                </Button>
                <Separator Classes="toolbar" />
                <Button Classes="toolbar" Command="{Binding #MapCanvas.RefitViewCommand}" ToolTip.Tip="Refit View">
                    <Image Source="{SvgImage /Assets/Icons/scan-eye.svg}" />
                </Button>

            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Height="24"
                Background="{StaticResource DMapBackground}"
                BorderBrush="{StaticResource DMapHighlight}"
                BorderThickness="0,2,0,0">
            <DockPanel Margin="8,0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource DMapForeground}"
                               Text="{Binding ConnectedPlayers, StringFormat='Players: {0}'}"
                               VerticalAlignment="Center" FontSize="11" />
                    <TextBlock Foreground="{StaticResource DMapForeground}"
                               Text="{Binding MemoryUsage}"
                               VerticalAlignment="Center" FontSize="11"
                               ToolTip.Tip="Memory usage" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Map Canvas + floating toolbar overlay -->
        <Panel>
            <controls:MapCanvas x:Name="MapCanvas"
                            MapImage="{Binding MapImage}"
                            FogMask="{Binding FogMask}"
                            IsDmMode="True"
                            FogOpacity="{Binding FogSettings.Opacity}"
                            FogType="{Binding FogSettings.SelectedFogType}"
                            FogColor="{Binding FogSettings.Color}"
                            FogSeed="{Binding FogSeed}"
                            IsFogGenerating="{Binding IsFogGenerating, Mode=OneWayToSource}"
                            ShowMap="{Binding IsMapVisible}"
                            BrushDiameter="{Binding BrushSettings.Diameter}"
                            ActiveTool="{Binding SelectedTool}"
                            BrushShape="{Binding BrushSettings.SelectedBrushShape}"
                            ShapeType="{Binding ShapeSettings.SelectedShapeType}"
                            ShapeCornerRadius="{Binding ShapeSettings.CornerRadius}"
                            CursorType="{Binding CursorSettings.SelectedCursorType}"
                            CursorSize="{Binding CursorSettings.Size}"
                            ShowCursorOnlyWhilePressed="{Binding CursorSettings.ShowOnlyWhilePressed}"
                            IsGridVisible="{Binding GridSettings.IsVisible}"
                            GridSquareSize="{Binding GridSettings.SquareSize}"
                            GridLineWidth="{Binding GridSettings.LineWidth}"
                            GridOpacity="{Binding GridSettings.Opacity}"
                            GridColor="{Binding GridSettings.Color}"
                            GridOffsetX="{Binding GridSettings.OffsetX}"
                            GridOffsetY="{Binding GridSettings.OffsetY}">
            </controls:MapCanvas>

            <Panel IsVisible="{Binding IsOverlayVisible}">
                <Border Margin="14"
                        BorderBrush="{StaticResource DMapForeground}"
                        BorderThickness="3"
                        CornerRadius="18"
                        Background="Transparent"
                        IsHitTestVisible="False"
                        IsVisible="{Binding IsUpdatesPaused}" />

                <Border Classes="overlay"
                        Margin="0,0,28,28"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        IsVisible="{Binding IsUpdatesPaused}">
                    <Button Background="Transparent"
                            BorderThickness="0"
                            Padding="10"
                            Command="{Binding TogglePauseUpdatesCommand}"
                            ToolTip.Tip="Resume Player Updates">
                        <Image Width="20"
                               Height="20"
                               Source="{SvgImage /Assets/Icons/radio-off.svg}" />
                    </Button>
                </Border>
            </Panel>

            <!-- Floating side toolbar -->
            <Grid ColumnDefinitions="Auto,Auto"
                  ColumnSpacing="10"
                  Margin="8,8,0,8"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Stretch"
                  IsVisible="{Binding IsOverlayVisible}">
                <Border Classes="overlay"
                        Padding="4"
                        VerticalAlignment="Top"
                        IsHitTestVisible="True">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="4">

                            <!-- Brush tool -->
                            <Button Classes="toolbox"
                                    Classes.toolSelected="{Binding IsBrushSelected}"
                                    Command="{Binding SelectBrushCommand}"
                                    ToolTip.Tip="Brush">
                                <Image Source="{SvgImage /Assets/Icons/brush.svg}" />
                            </Button>

                            <!-- Shape tools group -->
                            <Button Classes="toolbox"
                                    Classes.toolSelected="{Binding IsShapeSelected}"
                                    Command="{Binding SelectShapeCommand}"
                                    ToolTip.Tip="Shape">
                                <Image Source="{SvgImage /Assets/Icons/shapes.svg}" />
                            </Button>

                            <!-- Fog tool -->
                            <Button Classes="toolbox"
                                    Classes.toolSelected="{Binding IsFogSelected}"
                                    Command="{Binding SelectFogCommand}"
                                    ToolTip.Tip="Fog">
                                <Image Source="{SvgImage /Assets/Icons/cloud-fog.svg}" />
                            </Button>

                            <!-- Cursor tool -->
                            <Button Classes="toolbox"
                                    Classes.toolSelected="{Binding IsCursorSelected}"
                                    Command="{Binding SelectCursorCommand}"
                                    ToolTip.Tip="Cursor">
                                <Image Source="{SvgImage /Assets/Icons/crosshair.svg}" />
                            </Button>

                            <Button Classes="toolbox"
                                    Classes.toolSelected="{Binding IsGridSelected}"
                                    Command="{Binding SelectGridCommand}"
                                    ToolTip.Tip="Grid">
                                <Image Source="{SvgImage /Assets/Icons/grid-2x2.svg}" />
                            </Button>

                            <!-- Pan tool -->
                            <Button Classes="toolbox"
                                    Classes.toolSelected="{Binding IsPanSelected}"
                                    Command="{Binding SelectPanCommand}"
                                    ToolTip.Tip="Pan">
                                <Image Source="{SvgImage /Assets/Icons/hand.svg}" />
                            </Button>

                            <StackPanel IsVisible="{Binding ShowToolSettingsRailToggle}"
                                        Spacing="4">
                                <Separator Classes="toolbox" />
                                <Button Classes="toolbox"
                                        Command="{Binding ToggleToolSettingsPanelVisibilityCommand}"
                                        ToolTip.Tip="Show Tool Settings">
                                    <Image Source="{SvgImage /Assets/Icons/plus.svg}" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Panel Grid.Column="1"
                       VerticalAlignment="Top"
                       IsVisible="{Binding HasCurrentToolSettings}">
                    <Border Classes="overlay"
                            Padding="8"
                            VerticalAlignment="Top"
                            IsHitTestVisible="True"
                            IsVisible="{Binding IsToolSettingsPanelVisible}">
                        <Grid RowDefinitions="Auto,*"
                              RowSpacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Classes="toolSettingHeader"
                                           Text="{Binding CurrentToolSettings.Name}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Classes="toolbar"
                                        Command="{Binding ToggleToolSettingsPanelVisibilityCommand}"
                                        ToolTip.Tip="Hide Tool Settings">
                                    <Image Source="{SvgImage /Assets/Icons/minus.svg}" />
                                </Button>
                            </Grid>

                            <ScrollViewer Grid.Row="1"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ContentControl Content="{Binding CurrentToolSettings}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Panel>
            </Grid>
        </Panel>
    </DockPanel>

</UserControl>
