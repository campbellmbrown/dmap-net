<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DMap.App"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <!-- Palette -->
        <Color x:Key="DMapBackground">#0B0B2C</Color> <!-- "#0B0B2C" -->
        <Color x:Key="DMapHover">#20205c</Color> <!-- "#20205c" -->
        <Color x:Key="DMapSelected">#343475</Color> <!-- "#343475" -->
        <Color x:Key="DMapHighlight">#444499</Color> <!-- "#444499" -->
        <!-- <Color x:Key="DMapForeground">#A1A1E8</Color> "#A1A1E8" -->
        <Color x:Key="DMapForeground">#FFFFFF</Color> <!-- "#FFFFFF" -->

        <!-- https://github.com/AvaloniaUI/Avalonia/blob/master/src/Avalonia.Themes.Fluent/Controls/Menu.xaml -->
        <SolidColorBrush x:Key="MenuFlyoutPresenterBackground" Color="{StaticResource DMapBackground}" />
        <SolidColorBrush x:Key="MenuFlyoutPresenterBorderBrush" Color="{StaticResource DMapHighlight}" />
        <SolidColorBrush x:Key="MenuFlyoutItemForeground" Color="{StaticResource DMapForeground}" />
        <SolidColorBrush x:Key="MenuFlyoutItemBackground" Color="{StaticResource DMapBackground}" />
        <SolidColorBrush x:Key="MenuFlyoutItemForegroundPointerOver" Color="{StaticResource DMapForeground}" />
        <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPointerOver" Color="{StaticResource DMapHover}" />
        <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPressed" Color="{StaticResource DMapSelected}" />
        <SolidColorBrush x:Key="MenuFlyoutItemForegroundPressed" Color="{StaticResource DMapForeground}" />
        <SolidColorBrush x:Key="MenuFlyoutItemBackgroundDisabled" Color="{StaticResource DMapBackground}" />
        <SolidColorBrush x:Key="MenuFlyoutItemForegroundDisabled" Color="{StaticResource DMapForeground}" Opacity="0.6" />
        <Thickness x:Key="MenuFlyoutPresenterBorderThemeThickness">2</Thickness>
        <x:Double x:Key="MenuFlyoutSeparatorThemeHeight">2</x:Double>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />

        <Style Selector="Separator">
            <Setter Property="Background" Value="{StaticResource DMapHighlight}" />
        </Style>
        <Style Selector="Menu">
            <Setter Property="Background" Value="{StaticResource DMapBackground}" />
        </Style>

        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource DMapForeground}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <!-- The NumericUpDown template renders its border and background through a TextBox's internal
             PART_BorderElement. The TextBox ControlTheme overrides that element's background and border
             on :pointerover and :focus, so styles must target PART_BorderElement directly to take effect.
             https://github.com/AvaloniaUI/Avalonia/blob/12.0.1/src/Avalonia.Themes.Fluent/Controls/TextBox.xaml -->

        <!-- Hover: keep foreground colour, prevent TextBox ControlTheme from overriding it -->
        <Style Selector="NumericUpDown /template/ TextBox:pointerover">
            <Setter Property="Foreground" Value="{StaticResource DMapForeground}" />
        </Style>
        <!-- Focus: keep foreground colour -->
        <Style Selector="NumericUpDown /template/ TextBox:focus">
            <Setter Property="Foreground" Value="{StaticResource DMapForeground}" />
        </Style>
        <!-- The NumericUpDown template gives its inner TextBox Margin="-1" to overlap the ButtonSpinner border.
             We set BorderThickness="0" on the NumericUpDown so there is no border to overlap.
             https://github.com/AvaloniaUI/Avalonia/blob/12.0.1/src/Avalonia.Themes.Fluent/Controls/NumericUpDown.xaml -->
        <Style Selector="NumericUpDown /template/ TextBox:not(:disabled)">
            <Setter Property="Margin" Value="0" />
        </Style>
        <!-- Default border (pseudo-class required to beat TemplateBinding priority) -->
        <Style Selector="NumericUpDown /template/ TextBox:not(:pointerover):not(:focus) /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{StaticResource DMapHighlight}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <!-- Hover: highlight background -->
        <Style Selector="NumericUpDown /template/ TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{StaticResource DMapHover}" />
            <Setter Property="BorderBrush" Value="{StaticResource DMapHighlight}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <!-- Focus: selected background -->
        <Style Selector="NumericUpDown /template/ TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{StaticResource DMapSelected}" />
            <Setter Property="BorderBrush" Value="{StaticResource DMapHighlight}" />
        </Style>
    </Application.Styles>
</Application>
