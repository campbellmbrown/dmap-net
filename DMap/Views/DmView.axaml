<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DMap.ViewModels"
             xmlns:controls="using:DMap.Controls"
             xmlns:converters="using:DMap.Converters"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
             x:Class="DMap.Views.DmView"
             x:DataType="vm:DmViewModel">

    <UserControl.Resources>
        <converters:BrushShapeIconConverter x:Key="BrushShapeIconConverter" />
        <converters:ShapeTypeIconConverter x:Key="ShapeTypeIconConverter" />
    </UserControl.Resources>

    <DockPanel>
        <!-- Top bar: fixed controls + tool-specific settings -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    Margin="0" Height="40">
            <Button Content="Load Map" Command="{Binding LoadMapCommand}" Margin="4,0,0,0" VerticalAlignment="Center" />
            <Button Content="+" Command="{Binding ZoomInCommand}" Width="32" VerticalAlignment="Center" />
            <Button Content="-" Command="{Binding ZoomOutCommand}" Width="32" VerticalAlignment="Center" />
            <Button Content="Reset" Command="{Binding ResetViewCommand}" VerticalAlignment="Center" />
            <Separator Width="1" Margin="4,6" />
            <TextBlock Text="{Binding ConnectedPlayers, StringFormat='Players: {0}'}"
                       VerticalAlignment="Center" />
            <Separator Width="1" Margin="4,6" />

            <!-- Brush settings -->
            <StackPanel Orientation="Horizontal" Spacing="8"
                        IsVisible="{Binding IsBrushSelected}"
                        VerticalAlignment="Center">
                <ComboBox ItemsSource="{Binding BrushShapes}"
                          SelectedItem="{Binding SelectedBrushShape}"
                          Width="120" VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:CompileBindings="False">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Image Width="16" Height="16">
                                    <Image.Source>
                                        <svg:SvgImage Source="{Binding Converter={StaticResource BrushShapeIconConverter}}" />
                                    </Image.Source>
                                </Image>
                                <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="{Binding BrushDiameter, StringFormat='Diameter: {0}'}" VerticalAlignment="Center" />
                <Slider Minimum="10" Maximum="300" Value="{Binding BrushDiameter}"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Width="120" VerticalAlignment="Center" />
                <TextBlock Text="{Binding BrushSoftness, StringFormat='Softness: {0:F2}'}" VerticalAlignment="Center" />
                <Slider Minimum="0" Maximum="1" Value="{Binding BrushSoftness}"
                        TickFrequency="0.01" IsSnapToTickEnabled="True"
                        Width="100" VerticalAlignment="Center" />
                <TextBlock Text="{Binding BrushOpacity, StringFormat='Opacity: {0:F2}'}" VerticalAlignment="Center" />
                <Slider Minimum="0" Maximum="1" Value="{Binding BrushOpacity}"
                        TickFrequency="0.01" IsSnapToTickEnabled="True"
                        Width="100" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Shape settings -->
            <StackPanel Orientation="Horizontal" Spacing="8"
                        IsVisible="{Binding IsShapeSelected}"
                        VerticalAlignment="Center">
                <ComboBox ItemsSource="{Binding ShapeTypes}"
                          SelectedItem="{Binding SelectedShapeType}"
                          Width="130" VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:CompileBindings="False">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Image Width="16" Height="16">
                                    <Image.Source>
                                        <svg:SvgImage Source="{Binding Converter={StaticResource ShapeTypeIconConverter}}" />
                                    </Image.Source>
                                </Image>
                                <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="{Binding ShapeSoftness, StringFormat='Softness: {0:F2}'}" VerticalAlignment="Center" />
                <Slider Minimum="0" Maximum="1" Value="{Binding ShapeSoftness}"
                        TickFrequency="0.01" IsSnapToTickEnabled="True"
                        Width="100" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ShapeOpacity, StringFormat='Opacity: {0:F2}'}" VerticalAlignment="Center" />
                <Slider Minimum="0" Maximum="1" Value="{Binding ShapeOpacity}"
                        TickFrequency="0.01" IsSnapToTickEnabled="True"
                        Width="100" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>

        <!-- Side tool bar -->
        <Border DockPanel.Dock="Left" Width="52"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <StackPanel Spacing="4" Margin="4,8,4,0">

                <!-- Brush tool -->
                <Panel>
                    <Border Background="#30FFFFFF" CornerRadius="4"
                            IsVisible="{Binding IsBrushSelected}" />
                    <Button Command="{Binding SelectBrushCommand}"
                            Background="Transparent" Width="44" Height="44"
                            HorizontalContentAlignment="Center"
                            ToolTip.Tip="Brush">
                        <Image Source="{SvgImage /Assets/Icons/brush.svg}" Width="20" Height="20" />
                    </Button>
                </Panel>

                <!-- Shape tools group -->
                <Panel>
                    <Border Background="#30FFFFFF" CornerRadius="4"
                            IsVisible="{Binding IsShapeSelected}" />
                    <Button Command="{Binding SelectShapeCommand}"
                            Background="Transparent" Width="44" Height="44"
                            HorizontalContentAlignment="Center"
                            ToolTip.Tip="Shape">
                        <Image Source="{SvgImage /Assets/Icons/shapes.svg}" Width="20" Height="20" />
                    </Button>
                </Panel>

                <Separator Margin="4,2" />

                <!-- Pan tool -->
                <Panel>
                    <Border Background="#30FFFFFF" CornerRadius="4"
                            IsVisible="{Binding IsPanSelected}" />
                    <Button Command="{Binding SelectPanCommand}"
                            Background="Transparent" Width="44" Height="44"
                            HorizontalContentAlignment="Center"
                            ToolTip.Tip="Pan">
                        <Image Source="{SvgImage /Assets/Icons/hand.svg}" Width="20" Height="20" />
                    </Button>
                </Panel>

            </StackPanel>
        </Border>

        <!-- Map Canvas -->
        <controls:MapCanvas x:Name="MapCanvas"
                            MapImage="{Binding MapImage}"
                            FogMask="{Binding FogMask}"
                            ZoomLevel="{Binding ZoomLevel, Mode=TwoWay}"
                            OffsetX="{Binding OffsetX, Mode=TwoWay}"
                            OffsetY="{Binding OffsetY, Mode=TwoWay}"
                            IsDmMode="True"
                            FogOpacity="128"
                            BrushDiameter="{Binding BrushDiameter}"
                            ActiveTool="{Binding SelectedTool}"
                            BrushShape="{Binding SelectedBrushShape}"
                            ShapeType="{Binding SelectedShapeType}" />
    </DockPanel>

</UserControl>
