<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DMap.ViewModels"
             xmlns:controls="using:DMap.Controls"
             xmlns:converters="using:DMap.Converters"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
             x:Class="DMap.Views.DmView"
             x:DataType="vm:DmViewModel">

    <UserControl.Resources>
        <converters:BrushShapeIconConverter x:Key="BrushShapeIconConverter" />
        <converters:ShapeTypeIconConverter x:Key="ShapeTypeIconConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.statusbar">
            <Setter Property="Height" Value="18" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="4,0" />
        </Style>
        <Style Selector="Button.statusbar Image">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
        </Style>
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.toolbar Image">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
        </Style>
        <Style Selector="MenuItem Image">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
        </Style>
    </UserControl.Styles>

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}" />
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+Z" Command="{Binding RedoCommand}" />
    </UserControl.KeyBindings>

    <DockPanel>
        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="Open Map..." Command="{Binding LoadMapCommand}">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/map.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Exit" Command="{Binding ExitCommand}">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/door-open.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Zoom In" Command="{Binding ZoomInCommand}">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/zoom-in.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Zoom Out" Command="{Binding ZoomOutCommand}">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/zoom-out.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Reset View" Command="{Binding ResetViewCommand}">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/scaling.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Undo" Command="{Binding UndoCommand}" InputGesture="Ctrl+Z">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/undo-2.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Redo" Command="{Binding RedoCommand}" InputGesture="Ctrl+Y">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/redo-2.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Reveal All" Command="{Binding RevealAllCommand}">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/eye.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Refog All" Command="{Binding RefogAllCommand}">
                    <MenuItem.Icon>
                        <Image Source="{SvgImage /Assets/Icons/eye-off.svg}" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Top bar: tool-specific settings -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    Margin="0" Height="40">

            <!-- Brush settings -->
            <StackPanel Orientation="Horizontal" Spacing="8"
                        IsVisible="{Binding IsBrushSelected}"
                        VerticalAlignment="Center" Margin="4,0,0,0">
                <ComboBox ItemsSource="{Binding BrushShapes}"
                          SelectedItem="{Binding SelectedBrushShape}"
                          Width="120" VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:CompileBindings="False">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Image Width="16" Height="16">
                                    <Image.Source>
                                        <svg:SvgImage Source="{Binding Converter={StaticResource BrushShapeIconConverter}}" />
                                    </Image.Source>
                                </Image>
                                <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="{Binding BrushDiameter, StringFormat='Diameter: {0}'}" VerticalAlignment="Center" />
                <Slider Minimum="10" Maximum="300" Value="{Binding BrushDiameter}"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Width="120" VerticalAlignment="Center" />
                <TextBlock Text="{Binding BrushSoftness, StringFormat='Softness: {0:F2}'}" VerticalAlignment="Center" />
                <Slider Minimum="0" Maximum="1" Value="{Binding BrushSoftness}"
                        TickFrequency="0.01" IsSnapToTickEnabled="True"
                        Width="100" VerticalAlignment="Center" />
                <TextBlock Text="{Binding BrushOpacity, StringFormat='Opacity: {0:F2}'}" VerticalAlignment="Center" />
                <Slider Minimum="0" Maximum="1" Value="{Binding BrushOpacity}"
                        TickFrequency="0.01" IsSnapToTickEnabled="True"
                        Width="100" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Shape settings -->
            <StackPanel Orientation="Horizontal" Spacing="8"
                        IsVisible="{Binding IsShapeSelected}"
                        VerticalAlignment="Center" Margin="4,0,0,0">
                <ComboBox ItemsSource="{Binding ShapeTypes}"
                          SelectedItem="{Binding SelectedShapeType}"
                          Width="130" VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:CompileBindings="False">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Image Width="16" Height="16">
                                    <Image.Source>
                                        <svg:SvgImage Source="{Binding Converter={StaticResource ShapeTypeIconConverter}}" />
                                    </Image.Source>
                                </Image>
                                <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="{Binding ShapeSoftness, StringFormat='Softness: {0:F2}'}" VerticalAlignment="Center" />
                <Slider Minimum="0" Maximum="1" Value="{Binding ShapeSoftness}"
                        TickFrequency="0.01" IsSnapToTickEnabled="True"
                        Width="100" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ShapeOpacity, StringFormat='Opacity: {0:F2}'}" VerticalAlignment="Center" />
                <Slider Minimum="0" Maximum="1" Value="{Binding ShapeOpacity}"
                        TickFrequency="0.01" IsSnapToTickEnabled="True"
                        Width="100" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Height="24"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <DockPanel Margin="8,0" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding ConnectedPlayers, StringFormat='Players: {0}'}"
                           VerticalAlignment="Center" FontSize="11" />
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Button Classes="statusbar" Width="18" Command="{Binding UndoCommand}" ToolTip.Tip="Undo (Ctrl+Z)">
                        <Image Source="{SvgImage /Assets/Icons/undo-2.svg}" />
                    </Button>
                    <Button Classes="statusbar" Width="18" Command="{Binding RedoCommand}" ToolTip.Tip="Redo (Ctrl+Y)">
                        <Image Source="{SvgImage /Assets/Icons/redo-2.svg}" />
                    </Button>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Classes="statusbar" Width="18" Command="{Binding ZoomOutCommand}" ToolTip.Tip="Zoom Out">
                        <Image Source="{SvgImage /Assets/Icons/zoom-out.svg}" />
                    </Button>
                    <NumericUpDown Value="{Binding ZoomPercent}"
                                   Minimum="10" Maximum="1000" Increment="10"
                                   FormatString="0'%'"
                                   ShowButtonSpinner="False"
                                   Width="64" Height="20" FontSize="11"
                                   ToolTip.Tip="Zoom level" />
                    <Button Classes="statusbar" Width="18" Command="{Binding ZoomInCommand}" ToolTip.Tip="Zoom In">
                        <Image Source="{SvgImage /Assets/Icons/zoom-in.svg}" />
                    </Button>
                    <Separator Width="1" Margin="2,4" />
                    <Button Classes="statusbar" Width="18" Command="{Binding ResetViewCommand}" ToolTip.Tip="Reset View">
                        <Image Source="{SvgImage /Assets/Icons/scaling.svg}" />
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Map Canvas + floating toolbar overlay -->
        <Panel>
            <controls:MapCanvas x:Name="MapCanvas"
                            MapImage="{Binding MapImage}"
                            FogMask="{Binding FogMask}"
                            ZoomLevel="{Binding ZoomLevel, Mode=TwoWay}"
                            OffsetX="{Binding OffsetX, Mode=TwoWay}"
                            OffsetY="{Binding OffsetY, Mode=TwoWay}"
                            IsDmMode="True"
                            FogOpacity="128"
                            BrushDiameter="{Binding BrushDiameter}"
                            ActiveTool="{Binding SelectedTool}"
                            BrushShape="{Binding SelectedBrushShape}"
                            ShapeType="{Binding SelectedShapeType}" />

            <!-- Floating side toolbar -->
            <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="8,8,0,0"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="8"
                    BoxShadow="0 2 8 0 #40000000"
                    IsHitTestVisible="True">
                <StackPanel Spacing="4" Margin="4,8,4,8">

                    <!-- Brush tool -->
                    <Panel>
                        <Border Background="#30FFFFFF" CornerRadius="4"
                                IsVisible="{Binding IsBrushSelected}" />
                        <Button Classes="toolbar" Command="{Binding SelectBrushCommand}" ToolTip.Tip="Brush">
                            <Image Source="{SvgImage /Assets/Icons/brush.svg}" />
                        </Button>
                    </Panel>

                    <!-- Shape tools group -->
                    <Panel>
                        <Border Background="#30FFFFFF" CornerRadius="4"
                                IsVisible="{Binding IsShapeSelected}" />
                        <Button Classes="toolbar" Command="{Binding SelectShapeCommand}" ToolTip.Tip="Shape">
                            <Image Source="{SvgImage /Assets/Icons/shapes.svg}" />
                        </Button>
                    </Panel>

                    <Separator Margin="4,2" />

                    <!-- Pan tool -->
                    <Panel>
                        <Border Background="#30FFFFFF" CornerRadius="4"
                                IsVisible="{Binding IsPanSelected}" />
                        <Button Classes="toolbar" Command="{Binding SelectPanCommand}" ToolTip.Tip="Pan">
                            <Image Source="{SvgImage /Assets/Icons/hand.svg}" />
                        </Button>
                    </Panel>

                </StackPanel>
            </Border>
        </Panel>
    </DockPanel>

</UserControl>
