<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DMap.ViewModels.ToolSettings"
             xmlns:converters="using:DMap.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="DMap.Views.ToolSettings.FogToolSettingsView"
             x:DataType="vm:FogToolSettingsViewModel">

    <UserControl.Resources>
        <converters:FogTypeIconConverter x:Key="FogTypeIconConverter" />
    </UserControl.Resources>

    <StackPanel Spacing="8" MinWidth="200">
        <TextBlock Classes="toolSetting" Text="Fog Type" />
        <ComboBox ItemsSource="{Binding FogTypes}"
                  SelectedItem="{Binding SelectedFogType}"
                  HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
                <DataTemplate x:CompileBindings="False">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Image Width="16" Height="16" Source="{Binding Converter={StaticResource FogTypeIconConverter}}" />
                        <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Classes="toolSetting" Text="Fog Colour" VerticalAlignment="Center" />
            <Border Grid.Column="1"
                    BorderThickness="2"
                    BorderBrush="{StaticResource DMapHighlight}"
                    CornerRadius="4"
                    Padding="0">
                <ColorPicker Color="{Binding Color}"
                             IsEnabled="{Binding IsFogColorSelected}"
                             IsAlphaVisible="False"
                             IsAlphaEnabled="False"
                             IsColorPreviewVisible="False" />
            </Border>
        </Grid>
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Classes="toolSetting" Text="Fog Opacity" VerticalAlignment="Center" />
            <NumericUpDown Classes="toolSetting" Grid.Column="1" Value="{Binding Opacity}"
                           Minimum="0" Maximum="1" Increment="0.01" FormatString="0.00" />
        </Grid>
        <Slider Minimum="0" Maximum="1" Value="{Binding Opacity}"
                TickFrequency="0.01" IsSnapToTickEnabled="True"
                HorizontalAlignment="Stretch" />
    </StackPanel>
</UserControl>
