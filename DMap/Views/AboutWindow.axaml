<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DMap.ViewModels"
        x:Class="DMap.Views.AboutWindow"
        x:DataType="vm:AboutWindowViewModel"
        Classes="aboutWindow"
        Title="About DMap"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/avalonia-logo.ico"
        Background="{StaticResource DMapBackground}">

    <Window.Styles>
        <Style Selector="Window.aboutWindow">
            <Setter Property="TransparencyLevelHint" Value="None" />
        </Style>
        <Style Selector="Window.aboutWindow TextBlock, Window.aboutWindow SelectableTextBlock">
            <Setter Property="Foreground" Value="{StaticResource DMapForeground}" />
        </Style>
        <Style Selector="Window.aboutWindow HyperlinkButton">
            <Setter Property="Foreground" Value="{StaticResource DMapForeground}" />
        </Style>
        <Style Selector="Window.aboutWindow HyperlinkButton:pointerover">
            <Setter Property="Foreground" Value="{StaticResource DMapHighlight}" />
        </Style>
    </Window.Styles>

    <Border Padding="24"
            Background="{StaticResource DMapBackground}"
            BorderBrush="{StaticResource DMapHighlight}"
            BorderThickness="2">
        <StackPanel Spacing="12">
            <TextBlock Text="DMap"
                       FontSize="22"
                       FontWeight="Bold" />
            <Grid ColumnDefinitions="Auto,*"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="6">
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Version"
                           FontWeight="Bold" />
                <SelectableTextBlock Grid.Row="0"
                                     Grid.Column="1"
                                     Text="{Binding Version}"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas, Courier New, monospace" />
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="Revision"
                           FontWeight="Bold" />
                <SelectableTextBlock Grid.Row="1"
                                     Grid.Column="1"
                                     Text="{Binding GitSha}"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas, Courier New, monospace" />
            </Grid>
            <TextBlock Text="Source"
                       FontWeight="Bold"
                       Margin="0,8,0,0" />
            <HyperlinkButton Content="https://github.com/campbellmbrown/dmap-net"
                             NavigateUri="https://github.com/campbellmbrown/dmap-net"
                             HorizontalAlignment="Left"
                             Padding="0" />
            <TextBlock Text="Documentation"
                       FontWeight="Bold"
                       Margin="0,8,0,0" />
            <HyperlinkButton Content="https://campbellmbrown.github.io/dmap-net"
                             NavigateUri="https://campbellmbrown.github.io/dmap-net"
                             HorizontalAlignment="Left"
                             Padding="0" />
            <Button Classes="text"
                    Content="OK"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0"
                    IsDefault="True"
                    IsCancel="True"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Border>
</Window>
