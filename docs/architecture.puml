@startuml DMap Architecture

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho

package "Models" <<Rectangle>> {
    class FogMask {
        +Width : int
        +Height : int
        +Data : byte[]
        +this[x, y] : byte
        +Clone() : FogMask
    }

    class BrushSettings <<record>> {
        +Diameter : int
        +Softness : float
    }

    class MapSession <<record>> {
        +SessionId : Guid
        +MapWidth : int
        +MapHeight : int
    }

    enum AppRole {
        DungeonMaster
        Player
    }
}

package "Services.Brushes" <<Rectangle>> {
    interface IBrush {
        +Name : string
        +Apply(mask, x, y, settings) : PixelRect
    }

    class CircleBrush implements IBrush {
        +Apply(mask, x, y, settings) : PixelRect
    }
}

package "Services.Fog" <<Rectangle>> {
    interface IFogMaskService {
        +Mask : FogMask?
        +MaskChanged : event
        +Initialize(width, height)
        +ApplyBrush(brush, x, y, settings) : PixelRect
        +Replace(mask)
        +ApplyDelta(delta)
    }

    class FogMaskService implements IFogMaskService
}

package "Services.Networking" <<Rectangle>> {
    enum MessageType {
        SessionInfo
        MapImage
        FogDelta
        FogFull
    }

    class FogDelta {
        +X : int
        +Y : int
        +Width : int
        +Height : int
        +Data : byte[]
        +Serialize() : byte[]
        +{static} Deserialize(bytes) : FogDelta
        +{static} FromMask(mask, x, y, w, h) : FogDelta
    }

    class ProtocolFraming <<static>> {
        +{static} WriteFrameAsync(stream, type, payload)
        +{static} ReadFrameAsync(stream) : (Type, Payload)?
    }

    class DiscoveredDm <<record>> {
        +Name : string
        +TcpEndPoint : IPEndPoint
        +SessionId : Guid
    }

    interface IDiscoveryService {
        +DmDiscovered : event
        +StartBroadcastingAsync(session, tcpPort, ct)
        +StartListeningAsync(ct)
    }

    interface IDmHostService {
        +Port : int
        +ConnectedPlayerCount : int
        +PlayerCountChanged : event
        +StartAsync(ct)
        +SendMapImageAsync(bytes, ct)
        +SendSessionInfoAsync(session, mask, ct)
        +SendFogDeltaAsync(delta, ct)
        +SendFogFullAsync(mask, ct)
    }

    interface IPlayerClientService {
        +SessionInfoReceived : event
        +MapImageReceived : event
        +FogDeltaReceived : event
        +FogFullReceived : event
        +Disconnected : event
        +ConnectAsync(endpoint, ct)
        +DisconnectAsync()
    }

    class DiscoveryService implements IDiscoveryService
    class DmHostService implements IDmHostService
    class PlayerClientService implements IPlayerClientService
}

package "ViewModels" <<Rectangle>> {
    abstract class ViewModelBase {
        + (inherits ReactiveObject)
    }

    class MainWindowViewModel {
        +Content : ViewModelBase
        +NavigateTo(vm)
    }

    class StartViewModel {
        +StartAsDmCommand
        +StartAsPlayerCommand
    }

    class DmViewModel {
        +MapImage : Bitmap?
        +FogMask : FogMask?
        +BrushDiameter : int
        +BrushSoftness : double
        +OffsetX / OffsetY : double
        +ZoomLevel : double
        +ConnectedPlayers : int
        +LoadMapCommand
        +ZoomIn/Out/ResetCommand
        +ShowOpenFileDialog : Interaction
        +FogUpdated : event
        +OnBrushStroke(mapX, mapY)
        +InitializeNetworking(host, discovery)
    }

    class PlayerViewModel {
        +DiscoveredDms : ObservableCollection
        +SelectedDm : DiscoveredDm?
        +IsConnected : bool
        +StatusText : string
        +MapImage : Bitmap?
        +FogMask : FogMask?
        +OffsetX / OffsetY : double
        +ZoomLevel : double
        +ConnectCommand
        +DisconnectCommand
        +FogUpdated : event
        +InitializeNetworking(discovery, client)
        +StartDiscoveryAsync()
    }

    MainWindowViewModel --|> ViewModelBase
    StartViewModel --|> ViewModelBase
    DmViewModel --|> ViewModelBase
    PlayerViewModel --|> ViewModelBase
}

package "Views" <<Rectangle>> {
    class MainWindow <<ReactiveWindow>>
    class StartView <<UserControl>>
    class DmView <<ReactiveUserControl>>
    class PlayerView <<ReactiveUserControl>>
    class ViewLocator <<IDataTemplate>>
}

package "Controls" <<Rectangle>> {
    class MapCanvas <<Control>> {
        +MapImage : Bitmap?
        +FogMask : FogMask?
        +ZoomLevel : double
        +OffsetX / OffsetY : double
        +IsDmMode : bool
        +FogOpacity : byte
        +BrushDiameter : int
        +BrushStrokeApplied : event
        +RebuildFogBitmap()
        +InvalidateFogRegion(rect)
        -UpdateFogBitmapRegion(rect)
    }

    class BrushStrokeEventArgs {
        +MapX : int
        +MapY : int
    }
}

' Dependencies / composition

FogMaskService ..> IBrush : applies
FogMaskService o--> FogMask : owns
IFogMaskService ..> FogDelta : applies / replaces

CircleBrush ..> FogMask : modifies
CircleBrush ..> BrushSettings : reads

DmHostService ..> ProtocolFraming : uses
DmHostService ..> FogDelta : sends
DmHostService ..> MapSession : sends

PlayerClientService ..> ProtocolFraming : uses
PlayerClientService ..> FogDelta : receives
PlayerClientService ..> FogMask : produces
PlayerClientService ..> MapSession : produces

DiscoveryService ..> DiscoveredDm : produces
DiscoveryService ..> MapSession : broadcasts

MainWindowViewModel o--> "1" ViewModelBase : Content
StartViewModel --> MainWindowViewModel : navigates

DmViewModel --> IFogMaskService
DmViewModel --> IBrush
DmViewModel --> IDmHostService
DmViewModel --> IDiscoveryService

PlayerViewModel --> IFogMaskService
PlayerViewModel --> IDiscoveryService
PlayerViewModel --> IPlayerClientService

MainWindow ..> MainWindowViewModel : DataContext
MainWindow ..> ViewLocator : resolves views

DmView ..> DmViewModel : ViewModel
DmView ..> MapCanvas : hosts
PlayerView ..> PlayerViewModel : ViewModel
PlayerView ..> MapCanvas : hosts
StartView ..> StartViewModel : ViewModel

MapCanvas ..> FogMask : renders
MapCanvas ..> BrushStrokeEventArgs : raises

@enduml
